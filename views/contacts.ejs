<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document |
        <%= title %>
    </title>
</head>

<body>
    <%- include('./partials/nav.ejs') %>
        <div style="background-color: rgb(172, 110, 187);">
            <h1 style="text-transform:uppercase; text-align: center;">Contacts</h1>
            <div style="text-align: center;">
                <ul>
                    <% if(contacts.length) { contacts.forEach(({link,name})=>{ %>
                        <li>
                            <a href="<%= link %>">
                                <%= name %>
                            </a>
                        </li>
                        <%}) }%>
                </ul>
            </div>
        </div>

</body>

</html>